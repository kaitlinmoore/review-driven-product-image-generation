# === Project data ===
# Raw pulls are reproducible via pull_product_data.py and too large to track.
data/*/reviews.jsonl
# Filter spot-check outputs and their generator are excluded from the repo.
data/*/filter_spotcheck.txt
exploration/_spotcheck.py
# data/filter_caches/ IS committed — those are real scientific artifacts.
# All other per-product outputs (metadata.json, summary.json, images/,
# reviews_ranked.jsonl, prompt_context.txt, initial_prompt.txt,
# gate_comparison.csv) remain committed for now; curate before push.

# === Runtime / generated ===
*.log
runs/
# Smoke-test outputs from the __main__ blocks in src/gen_image_*.py.
# The smoke-test code is retained for grader / env verification; the images
# themselves are one-time verification artifacts.
*_smoke_test.png

# === IDE / OS ===
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# === Model / framework caches ===
.cache/

# === Replay cache ===
# replay_cache/ contents are INTENTIONALLY committed — they are the canonical
# record that lets a grader reproduce the pipeline offline with REPLAY_MODE=replay.
# See replay_cache/README.md and REPRODUCIBILITY.md for details.
